[app]
title = Sky Kite Island Odyssey
package.name = skykiteislandodyssey
package.domain = com.yourgame
source.dir = .
source.include_exts = py,png,jpg,jpeg,gif,mp3,wav,ogg,ttf,atlas,kv,json,xml
version = 1.0
requirements = python3,pygame,sdl2,sdl2_image,sdl2_mixer,sdl2_ttf
orientation = landscape
fullscreen = 1
android.permissions = INTERNET,VIBRATE
android.api = 33
android.minapi = 21
android.ndk = 25b
android.sdk = 33
android.ndk_api = 21
android.accept_sdk_license = True
android.arch = armeabi-v7a
log_level = 2
warn_on_root = 1

[buildozer]
log_level = 2
warn_on_root = 1
